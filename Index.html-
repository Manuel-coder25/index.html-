<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Neon Rush - Arcade Survival</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            touch-action: none;
            -webkit-touch-callout: none;
            -webkit-user-select: none;
            user-select: none;
        }
        
        body {
            background: #0a0a0a;
            overflow: hidden;
            font-family: 'Segoe UI', system-ui, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        
        #gameContainer {
            position: relative;
            width: 100%;
            max-width: 600px;
            aspect-ratio: 3/4;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 0 50px rgba(0, 255, 255, 0.3);
        }
        
        canvas {
            display: block;
            width: 100%;
            height: 100%;
        }
        
        .ui-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 20px;
        }
        
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            pointer-events: auto;
        }
        
        .score-display {
            color: #fff;
            font-size: 28px;
            font-weight: 900;
            text-shadow: 0 0 20px rgba(0, 255, 255, 0.8);
            letter-spacing: 2px;
        }
        
        .coins-display {
            background: linear-gradient(135deg, #ffd700, #ffed4e);
            color: #000;
            padding: 8px 16px;
            border-radius: 20px;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 5px;
            box-shadow: 0 4px 15px rgba(255, 215, 0, 0.4);
        }
        
        .menu-screen, .game-over-screen, .shop-screen {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(10, 10, 10, 0.95);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 20px;
            pointer-events: auto;
            z-index: 10;
            backdrop-filter: blur(10px);
        }
        
        .hidden {
            display: none !important;
        }
        
        h1 {
            color: #fff;
            font-size: 48px;
            text-transform: uppercase;
            letter-spacing: 4px;
            text-shadow: 0 0 30px rgba(0, 255, 255, 0.8);
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        .btn {
            background: linear-gradient(135deg, #00d4ff, #0099cc);
            color: white;
            border: none;
            padding: 18px 50px;
            font-size: 20px;
            font-weight: 800;
            border-radius: 50px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: all 0.3s;
            box-shadow: 0 10px 30px rgba(0, 212, 255, 0.4);
            position: relative;
            overflow: hidden;
        }
        
        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(0, 212, 255, 0.6);
        }
        
        .btn:active {
            transform: translateY(-1px);
        }
        
        .btn.secondary {
            background: linear-gradient(135deg, #ff6b6b, #ee5a5a);
            box-shadow: 0 10px 30px rgba(255, 107, 107, 0.4);
        }
        
        .btn.premium {
            background: linear-gradient(135deg, #ffd700, #ffed4e);
            color: #000;
            box-shadow: 0 10px 30px rgba(255, 215, 0, 0.4);
        }
        
        .stats {
            color: #aaa;
            font-size: 14px;
            text-align: center;
            line-height: 1.6;
        }
        
        .shop-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            padding: 20px;
            max-height: 60%;
            overflow-y: auto;
        }
        
        .shop-item {
            background: rgba(255,255,255,0.1);
            border: 2px solid rgba(255,255,255,0.2);
            border-radius: 15px;
            padding: 15px;
            text-align: center;
            color: white;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .shop-item:hover {
            border-color: #00d4ff;
            transform: scale(1.05);
        }
        
        .shop-item.owned {
            border-color: #00ff88;
            opacity: 0.7;
        }
        
        .skin-preview {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            margin: 0 auto 10px;
            box-shadow: 0 0 20px currentColor;
        }
        
        .reward-ad-btn {
            position: absolute;
            bottom: 100px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(135deg, #9b59b6, #8e44ad);
            font-size: 16px;
            padding: 12px 30px;
        }
        
        .controls-hint {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            color: rgba(255,255,255,0.5);
            font-size: 14px;
            text-align: center;
        }
        
        .interstitial-ad {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #000;
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 100;
            color: white;
        }
        
        .ad-timer {
            font-size: 48px;
            color: #ff6b6b;
            margin-bottom: 20px;
        }
        
        .progress-bar {
            width: 200px;
            height: 4px;
            background: rgba(255,255,255,0.2);
            border-radius: 2px;
            overflow: hidden;
            margin-top: 10px;
        }
        
        .progress-fill {
            height: 100%;
            background: #00d4ff;
            width: 0%;
            transition: width 0.1s;
        }
    </style>
</head>
<body>
    <div id="gameContainer">
        <canvas id="gameCanvas"></canvas>
        
        <!-- Main Menu -->
        <div id="mainMenu" class="menu-screen">
            <h1>Neon Rush</h1>
            <div class="stats">
                High Score: <span id="menuHighScore">0</span><br>
                Total Coins: <span id="menuCoins">0</span>
            </div>
            <button class="btn" onclick="game.start()">Play Now</button>
            <button class="btn secondary" onclick="game.openShop()">Shop</button>
            <button class="btn premium" onclick="game.watchAdForCoins()">💰 Free Coins</button>
        </div>
        
        <!-- Shop -->
        <div id="shopScreen" class="shop-screen hidden">
            <h2 style="color: white; margin-bottom: 10px;">Skin Shop</h2>
            <div class="coins-display" style="margin-bottom: 20px;">
                <span>🪙</span>
                <span id="shopCoins">0</span>
            </div>
            <div class="shop-grid" id="shopGrid"></div>
            <button class="btn secondary" onclick="game.closeShop()">Back</button>
        </div>
        
        <!-- Game Over -->
        <div id="gameOver" class="game-over-screen hidden">
            <h2 style="color: #ff6b6b; font-size: 36px;">GAME OVER</h2>
            <div class="stats">
                Score: <span id="finalScore">0</span><br>
                Coins Earned: <span id="earnedCoins">0</span><br>
                <span id="newRecord" style="color: #ffd700; display: none;">🏆 NEW RECORD!</span>
            </div>
            <button class="btn" onclick="game.restart()">Try Again</button>
            <button class="btn premium" onclick="game.continueWithAd()">▶ Continue (Ad)</button>
            <button class="btn secondary" onclick="game.toMenu()">Main Menu</button>
        </div>
        
        <!-- Interstitial Ad Simulation -->
        <div id="interstitialAd" class="interstitial-ad">
            <div class="ad-timer">5</div>
            <div>Advertisement</div>
            <div class="progress-bar"><div class="progress-fill" id="adProgress"></div></div>
        </div>
        
        <!-- HUD -->
        <div class="ui-layer" id="hud" style="pointer-events: none;">
            <div class="top-bar">
                <div class="score-display" id="scoreDisplay">0</div>
                <div class="coins-display">
                    <span>🪙</span>
                    <span id="coinDisplay">0</span>
                </div>
            </div>
        </div>
        
        <div class="controls-hint" id="controlsHint">Tap or drag to move • Avoid red enemies • Collect coins</div>
    </div>

    <script>
        // Game Engine
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        
        // Set canvas size
        function resize() {
            const container = document.getElementById('gameContainer');
            canvas.width = container.clientWidth;
            canvas.height = container.clientHeight;
        }
        resize();
        window.addEventListener('resize', resize);
        
        // Game State
        const game = {
            state: 'menu', // menu, playing, gameover, shop
            score: 0,
            coins: parseInt(localStorage.getItem('neonRushCoins')) || 0,
            highScore: parseInt(localStorage.getItem('neonRushHighScore')) || 0,
            selectedSkin: localStorage.getItem('neonRushSkin') || 'default',
            player: null,
            enemies: [],
            coins: [],
            particles: [],
            lastTime: 0,
            spawnTimer: 0,
            coinTimer: 0,
            difficulty: 1,
            canContinue: true,
            
            skins: {
                default: { color: '#00d4ff', glow: '#00d4ff', cost: 0, owned: true },
                gold: { color: '#ffd700', glow: '#ffed4e', cost: 500, owned: false },
                ruby: { color: '#ff006e', glow: '#ff006e', cost: 1000, owned: false },
                matrix: { color: '#00ff00', glow: '#00ff00', cost: 1500, owned: false },
                void: { color: '#9b59b6', glow: '#e74c3c', cost: 2000, owned: false }
            }
        };
        
        // Initialize skins from storage
        const ownedSkins = JSON.parse(localStorage.getItem('neonRushOwnedSkins')) || ['default'];
        ownedSkins.forEach(skin => {
            if (game.skins[skin]) game.skins[skin].owned = true;
        });
        
        // Player Class
        class Player {
            constructor() {
                this.x = canvas.width / 2;
                this.y = canvas.height - 100;
                this.radius = 20;
                this.targetX = this.x;
                this.speed = 0.15;
                this.trail = [];
            }
            
            update(dt) {
                // Smooth movement
                this.x += (this.targetX - this.x) * this.speed;
                
                // Keep in bounds
                this.x = Math.max(this.radius, Math.min(canvas.width - this.radius, this.x));
                
                // Trail effect
                this.trail.push({ x: this.x, y: this.y, alpha: 1 });
                this.trail.forEach(t => t.alpha -= 0.05);
                this.trail = this.trail.filter(t => t.alpha > 0);
            }
            
            draw() {
                const skin = game.skins[game.selectedSkin];
                
                // Draw trail
                this.trail.forEach(t => {
                    ctx.beginPath();
                    ctx.arc(t.x, t.y, this.radius * 0.8, 0, Math.PI * 2);
                    ctx.fillStyle = skin.color + Math.floor(t.alpha * 255).toString(16).padStart(2, '0');
                    ctx.fill();
                });
                
                // Draw player
                ctx.shadowBlur = 20;
                ctx.shadowColor = skin.glow;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.fillStyle = skin.color;
                ctx.fill();
                
                // Inner core
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius * 0.6, 0, Math.PI * 2);
                ctx.fillStyle = '#fff';
                ctx.fill();
                ctx.shadowBlur = 0;
            }
        }
        
        // Enemy Class
        class Enemy {
            constructor() {
                this.radius = 15 + Math.random() * 20;
                this.x = Math.random() * (canvas.width - this.radius * 2) + this.radius;
                this.y = -this.radius;
                this.speed = 2 + Math.random() * 3 + (game.difficulty * 0.5);
                this.rotation = 0;
                this.rotationSpeed = (Math.random() - 0.5) * 0.1;
            }
            
            update(dt) {
                this.y += this.speed;
                this.rotation += this.rotationSpeed;
            }
            
            draw() {
                ctx.save();
                ctx.translate(this.x, this.y);
                ctx.rotate(this.rotation);
                ctx.shadowBlur = 15;
                ctx.shadowColor = '#ff006e';
                
                // Draw spike shape
                ctx.beginPath();
                for (let i = 0; i < 5; i++) {
                    const angle = (i * Math.PI * 2) / 5;
                    const r = i % 2 === 0 ? this.radius : this.radius * 0.5;
                    ctx.lineTo(Math.cos(angle) * r, Math.sin(angle) * r);
                }
                ctx.closePath();
                ctx.fillStyle = '#ff006e';
                ctx.fill();
                ctx.restore();
                ctx.shadowBlur = 0;
            }
        }
        
        // Coin Class
        class Coin {
            constructor() {
                this.radius = 12;
                this.x = Math.random() * (canvas.width - this.radius * 2) + this.radius;
                this.y = -this.radius;
                this.speed = 2;
                this.collected = false;
            }
            
            update(dt) {
                this.y += this.speed;
            }
            
            draw() {
                if (this.collected) return;
                
                ctx.shadowBlur = 15;
                ctx.shadowColor = '#ffd700';
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.fillStyle = '#ffd700';
                ctx.fill();
                
                // Shine
                ctx.beginPath();
                ctx.arc(this.x - 3, this.y - 3, this.radius * 0.3, 0, Math.PI * 2);
                ctx.fillStyle = '#fff';
                ctx.fill();
                ctx.shadowBlur = 0;
            }
        }
        
        // Particle Class
        class Particle {
            constructor(x, y, color) {
                this.x = x;
                this.y = y;
                this.vx = (Math.random() - 0.5) * 10;
                this.vy = (Math.random() - 0.5) * 10;
                this.life = 1;
                this.color = color;
            }
            
            update(dt) {
                this.x += this.vx;
                this.y += this.vy;
                this.life -= 0.02;
            }
            
            draw() {
                ctx.globalAlpha = this.life;
                ctx.fillStyle = this.color;
                ctx.fillRect(this.x, this.y, 4, 4);
                ctx.globalAlpha = 1;
            }
        }
        
        // Input handling
        function handleInput(x) {
            if (game.state === 'playing' && game.player) {
                game.player.targetX = x;
            }
        }
        
        canvas.addEventListener('mousemove', e => {
            const rect = canvas.getBoundingClientRect();
            handleInput(e.clientX - rect.left);
        });
        
        canvas.addEventListener('touchmove', e => {
            e.preventDefault();
            const rect = canvas.getBoundingClientRect();
            handleInput(e.touches[0].clientX - rect.left);
        }, { passive: false });
        
        canvas.addEventListener('touchstart', e => {
            const rect = canvas.getBoundingClientRect();
            handleInput(e.touches[0].clientX - rect.left);
        }, { passive: false });
        
        // Game methods
        game.start = function() {
            this.state = 'playing';
            this.score = 0;
            this.difficulty = 1;
            this.player = new Player();
            this.enemies = [];
            this.coins = [];
            this.particles = [];
            this.canContinue = true;
            
            document.getElementById('mainMenu').classList.add('hidden');
            document.getElementById('gameOver').classList.add('hidden');
            document.getElementById('hud').style.pointerEvents = 'none';
            document.getElementById('controlsHint').style.display = 'block';
            
            setTimeout(() => {
                document.getElementById('controlsHint').style.display = 'none';
            }, 3000);
            
            this.updateUI();
        };
        
        game.restart = function() {
            // Show interstitial ad every 3 restarts
            if (Math.random() < 0.33) {
                this.showInterstitial(() => this.start());
            } else {
                this.start();
            }
        };
        
        game.toMenu = function() {
            document.getElementById('gameOver').classList.add('hidden');
            document.getElementById('mainMenu').classList.remove('hidden');
            this.state = 'menu';
            this.updateMenuUI();
        };
        
        game.gameOver = function() {
            this.state = 'gameover';
            
            // Check high score
            const newRecord = this.score > this.highScore;
            if (newRecord) {
                this.highScore = this.score;
                localStorage.setItem('neonRushHighScore', this.highScore);
            }
            
            // Award coins (1 coin per 10 points)
            const earned = Math.floor(this.score / 10);
            this.coins += earned;
            localStorage.setItem('neonRushCoins', this.coins);
            
            document.getElementById('finalScore').textContent = this.score;
            document.getElementById('earnedCoins').textContent = earned;
            document.getElementById('newRecord').style.display = newRecord ? 'block' : 'none';
            document.getElementById('gameOver').classList.remove('hidden');
            
            this.updateMenuUI();
        };
        
        game.continueWithAd = function() {
            if (!this.canContinue) return;
            this.showInterstitial(() => {
                this.state = 'playing';
                this.canContinu
